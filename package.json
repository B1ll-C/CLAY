{
  "name": "clay-workspace",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "mobile",
    "backend",
    "shared"
  ],
  "scripts": {
    "start": "npm run start --workspace=mobile",
    "android": "npm run android --workspace=mobile",
    "ios": "npm run ios --workspace=mobile",
    "web": "npm run web --workspace=mobile",
    "lint": "npm run lint --workspace=mobile",
    "backend:dev": "npm run dev --workspace=backend",
    "backend:build": "npm run build --workspace=backend"
  }
}
